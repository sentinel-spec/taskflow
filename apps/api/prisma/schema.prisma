generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

enum WorkspaceUseCase {
  WORK
  PERSONAL
  STUDY
  OTHER
}

model User {
  id         Int     @id @default(autoincrement())
  email      String  @unique
  password   String
  firstName  String? @map("first_name")
  lastName   String? @map("last_name")
  isActive   Boolean @default(true) @map("is_active")
  isVerified Boolean @default(false) @map("is_verified")
  avatarUrl  String? @map("avatar_url")
  roles      Role[]  @default([USER])

  workspaces WorkspaceMember[]
  projects   ProjectMember[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Workspace {
  id          Int              @id @default(autoincrement())
  name        String
  slug        String           @unique
  description String?
  logoUrl     String?          @map("logo_url")
  coverImage  String?          @map("cover_image")
  teamSize    String?          @map("team_size")
  useCase     WorkspaceUseCase @default(WORK) @map("use_case")

  members  WorkspaceMember[]
  invitations WorkspaceInvitation[]
  projects Project[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("workspaces")
}

model WorkspaceInvitation {
  id          String        @id @default(cuid())
  workspaceId Int           @map("workspace_id")
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String
  role        WorkspaceRole @default(MEMBER)
  token       String?
  accepted    Boolean       @default(false)
  respondedAt DateTime?     @map("responded_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, email])
  @@map("workspace_invitations")
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String
  identifier  String
  description String?
  workspaceId Int       @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  logoType    String?   @map("logo_type")
  icon        String?
  color       String?
  coverImage  String?   @map("cover_image")

  isPublic   Boolean @default(false) @map("is_public")
  isArchived Boolean @default(false) @map("is_archived")

  members ProjectMember[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([workspaceId, identifier])
  @@map("projects")
}

model ProjectMember {
  id        Int @id @default(autoincrement())
  userId    Int @map("user_id")
  projectId Int @map("project_id")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, projectId])
  @@map("project_members")
}

model WorkspaceMember {
  id          Int           @id @default(autoincrement())
  userId      Int           @map("user_id")
  workspaceId Int           @map("workspace_id")
  role        WorkspaceRole @default(MEMBER)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

model SystemSettings {
  key           String   @id @default("default")
  timezone      String   @default("UTC")
  locale        String   @default("en-US")
  mailEnabled   Boolean  @default(false) @map("mail_enabled")
  mailFromEmail String   @default("") @map("mail_from_email")
  mailFromName  String   @default("") @map("mail_from_name")
  aiEnabled     Boolean  @default(true) @map("ai_enabled")
  aiProvider    String   @default("openrouter") @map("ai_provider")
  aiModel       String   @default("openai/gpt-4.1-mini") @map("ai_model")
  aiBaseUrl     String   @default("https://openrouter.ai/api/v1") @map("ai_base_url")
  aiApiKey      String?  @map("ai_api_key")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
